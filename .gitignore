# Environment / secrets
.env
.env.all
*.env.local
*.env.secret

# ============================================================================
# INTERMEDIATE data (pipeline scratch; regeneratable; NEVER committed)
# ============================================================================
# Raw upstream clones
data/mirai_repo/
data/forecastbench_repo/
data/fb_raw/

# GDELT-CAMEO intermediate tables
data/gdelt_cameo/kg_raw/
data/gdelt_cameo/kg_tmp/
data/gdelt_cameo/data_kg.csv
data/gdelt_cameo/data_news.csv
data/gdelt_cameo/data_news_full.csv
data/gdelt_cameo/test/test_kg.csv

# legacy (pre-rename)
data/mirai_2024/
data/mirai_extracted/

# Bulk formats
data/*.zip
data/*.sqlite
data/*.db

# ForecastBench-adjacent large blobs (re-fetchable)
data/gdelt_articles.jsonl
data/gdelt_articles_supplement.jsonl
data/fb_articles_full.jsonl
data/metaculus_questions.jsonl
data/metaculus_news.jsonl

# Per-FD news enrichment caches (re-fetchable via fetch_*_news.py scripts;
# total size ~150 MB, grows on every run; keep out of git)
data/forecastbench/forecastbench_articles.jsonl
data/gdelt_cameo/gdelt_cameo_news.jsonl
data/earnings/earnings_articles.jsonl
data/earnings/earnings_articles.jsonl.pre_spam_filter

# ETD (Event Timeline Dossier) extraction outputs — regeneratable via
# scripts/articles_to_facts.py. The SPEC + schema + prompt live under docs/
# and ARE committed; only the per-run outputs are ignored.
data/etd/facts.v*.jsonl
data/etd/facts.current
data/etd/facts.errors.jsonl
data/etd/extract_runs.jsonl
data/etd/smoke_dump_*.json

# ETD audit ephemerals (regeneratable; only per-cutoff post-publish summary
# + facts_vs_articles markdown are committed as paper-referenced artefacts)
data/etd/audit/*.log
data/etd/audit/delta_*.jsonl
data/etd/audit/*_diffs.jsonl
data/etd/audit/empty_*.md
data/etd/audit/empty_*.jsonl
data/etd/audit/error_triage.md
data/etd/audit/verifier_*.md
data/etd/audit/verifier_*.jsonl
data/etd/audit/recovery_meta.json
data/etd/audit/audit_report.md

# Local OpenAI Batch output / request caches (regeneratable, 100MB-1.5GB each)
data/etd_openai_batches/

# Pipeline STAGING (current live state — mutable between builds)
data/unified/articles.jsonl
data/unified/article_embeddings.npy
data/unified/article_embeddings.*.npy
data/unified/forecast_embeddings.npy
data/unified/forecast_embeddings.*.npy
data/unified/*.fp.txt
data/unified/*.prev_*.txt

# Versioned snapshots (preserved for audit, NOT for shipping)
data/staged/

# ============================================================================
# SHIPPED benchmark (committed — this is the deliverable)
# ============================================================================
# Explicit un-ignore: benchmark/data/ is the shipped, versioned benchmark.
# Large files like articles.jsonl are still committed (they're part of the
# dataset release). Use Git LFS if they exceed GitHub's 100 MB file limit.
!benchmark/data/
!benchmark/data/**

# Ignore Python-generated artifacts under benchmark/
benchmark/**/__pycache__/
benchmark/**/*.pyc
benchmark/**/*.pyo

# ============================================================================
# AUDIT material (diagnostic; not shipped)
# ============================================================================
benchmark/audit/

# ============================================================================
# Experiment artifacts
# ============================================================================
results/raw/
benchmark/results/*/*/*/*.log

# ============================================================================
# Python / OS
# ============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDEs
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
package-lock.json
results/batch_jobs.json
results/processed/metrics_b*.json
results/processed/predictions_b*.jsonl
